{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "client_event_v1.schema.json",
  "title": "client_event_v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "ts",
    "type",
    "confirmer",
    "stamp"
  ],
  "properties": {
    "ts": {
      "type": "string"
    },
    "confirmer": {
      "type": "string"
    },
    "stamp": {
      "type": "string"
    },
    "type": {
      "enum": [
        "intake_answer",
        "client_approved",
        "client_rejected",
        "voice_rating",
        "batch_rating",
        "compare_verdict",
        "version_verdict",
        "occasion_gold",
        "competitor_reference",
        "pick_selected",
        "red_line_added",
        "red_line_relaxed",
        "goal_declared",
        "capacity_declared",
        "truth_confirmed",
        "payment_received",
        "renewal",
        "scope_change",
        "referral",
        "offboarding_request",
        "approver_change",
        "blackout_flip",
        "crystallize_accepted",
        "crystallize_rejected",
        "published",
        "publish_failed",
        "review_received"
      ]
    },
    "subject": {
      "type": "string"
    },
    "rating": {
      "type": [
        "number",
        "null"
      ]
    },
    "reason_code": {
      "enum": [
        "culture_breach",
        "off_voice",
        "wrong_goal",
        "too_generic",
        "factual_error",
        "unexplained",
        null
      ]
    },
    "note": {
      "type": "string"
    }
  }
}