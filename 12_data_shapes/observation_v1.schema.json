{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ogz-knowledge/schemas/observation_v1.schema.json",
  "title": "Observation v1",
  "description": "A single content observation — what Claude Code produces when analysing one post, image, or video from a benchmark account.",
  "type": "object",
  "required": [
    "observation_ulid",
    "schema_version",
    "account_handle_normalized",
    "account_ulid",
    "sector",
    "content_ref",
    "visual_observations",
    "compliance_check",
    "cultural_notes",
    "quality_assessment",
    "provenance"
  ],
  "additionalProperties": false,
  "properties": {
    "observation_ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "account_handle_normalized": {
      "type": "string",
      "description": "External-facing anonymized label from the parent benchmark account."
    },
    "account_ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "sector": {
      "type": "string"
    },
    "occasion": {
      "type": [
        "string",
        "null"
      ],
      "description": "Canonical occasion slug: evergreen | ramadan | eid_al_fitr | eid_al_adha | national_day | founding_day | national_sports_day | summer_campaign | winter_seasonal | graduation_season | sporting_event | brand_campaign | vision_2030 | hajj | back_to_school | etc."
    },
    "content_ref": {
      "type": "object",
      "required": [
        "filename",
        "platform",
        "content_type"
      ],
      "additionalProperties": false,
      "properties": {
        "filename": {
          "type": "string",
          "description": "Source file in _inbox/ or _calibration_set/content/."
        },
        "platform": {
          "type": "string",
          "enum": [
            "instagram",
            "tiktok",
            "snapchat",
            "youtube",
            "x",
            "other"
          ]
        },
        "content_type": {
          "type": "string",
          "enum": [
            "image",
            "video",
            "carousel_slide",
            "story",
            "reel"
          ]
        },
        "capture_date": {
          "type": "string",
          "format": "date",
          "description": "When the content was posted, if known."
        },
        "source_url": {
          "type": "string"
        },
        "video_duration_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Duration in seconds for video/reel content. Null for image/carousel."
        },
        "aspect_ratio": {
          "type": [
            "string",
            "null"
          ],
          "description": "e.g. square_1x1 / portrait_4x5 / vertical_9x16 / landscape_16x9"
        },
        "cut_count": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of scene cuts detected by ffmpeg scdet"
        },
        "avg_shot_duration": {
          "type": [
            "number",
            "null"
          ],
          "description": "Average shot duration in seconds"
        },
        "editing_pace": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "viral_fast",
            "fast",
            "medium",
            "slow",
            null
          ],
          "description": "Editing pace label"
        },
        "carousel_slide_count": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of slides in the carousel (from local file count)"
        },
        "day_of_week": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "monday",
            "tuesday",
            "wednesday",
            "thursday",
            "friday",
            "saturday",
            "sunday",
            null
          ],
          "description": "Day of week the content was posted (derived from capture_date)"
        },
        "likes_count": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Real likes count from Apify extraction"
        },
        "comments_count": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Real comments count from Apify extraction"
        },
        "engagement_total": {
          "type": [
            "integer",
            "null"
          ],
          "description": "likes_count + comments_count"
        },
        "followers_at_capture": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Account followers at time of extraction"
        },
        "engagement_rate": {
          "type": [
            "number",
            "null"
          ],
          "description": "engagement_total / followers_at_capture"
        },
        "display_url": {
          "type": [
            "string",
            "null"
          ],
          "description": "Instagram display image URL from Apify"
        },
        "video_url": {
          "type": [
            "string",
            "null"
          ],
          "description": "Instagram video URL from Apify"
        }
      }
    },
    "visual_observations": {
      "type": "object",
      "required": [
        "composition_style"
      ],
      "additionalProperties": false,
      "properties": {
        "composition_style": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 3,
          "description": "e.g. 'overhead tabletop spread', 'product hero close-up', 'architectural framing'"
        },
        "lighting": {
          "type": "string"
        },
        "color_palette_dominant": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "color_palette": {
          "type": [
            "object",
            "null"
          ],
          "description": "Extracted from local image via PIL pixel analysis",
          "additionalProperties": false,
          "properties": {
            "dominant_colors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "warmth": {
              "type": [
                "string",
                "null"
              ]
            },
            "palette_type": {
              "type": [
                "string",
                "null"
              ]
            },
            "primary_family": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "human_presence": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "True if a human face is detected in the image via OpenCV"
        },
        "face_count": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of faces detected via OpenCV Haar cascade"
        },
        "props_visible": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "setting": {
          "type": "string"
        },
        "characters_visible": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 0
            },
            "gender_presentation": {
              "type": "string"
            },
            "wardrobe_notes": {
              "type": "string"
            },
            "gesture_notes": {
              "type": "string"
            }
          }
        },
        "text_overlays": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "language"
            ],
            "additionalProperties": false,
            "properties": {
              "language": {
                "type": "string"
              },
              "content_summary": {
                "type": "string"
              }
            }
          }
        },
        "notable_visual_elements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visual_complexity_score": {
          "type": [
            "integer",
            "null"
          ],
          "description": "props_count + character_count + text_overlay_count"
        },
        "visual_complexity": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "minimal",
            "simple",
            "moderate",
            "complex",
            null
          ],
          "description": "minimal (0-1) / simple (2-3) / moderate (4-6) / complex (7+)"
        },
        "scene_type": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "indoor",
            "outdoor",
            "studio",
            "graphic",
            "mixed",
            null
          ],
          "description": "Video scene environment detected by GPT-4o-mini vision"
        },
        "text_overlay_visible": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Whether text overlays are visible in the video frame"
        },
        "arabic_text_visible": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Whether Arabic text is visible in the video frame"
        },
        "product_visible": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Whether a product is visible in the video frame"
        },
        "brand_logo_visible": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Whether a brand logo is visible in the video frame"
        },
        "notable_phrases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "ADDITIVE 2026-06-11: phrases visible in the visual (signage/packaging). 2,492 records already carry it; legalized per SCHEMA_EVOLUTION (add, never break)."
        }
      }
    },
    "voice_observations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "arabic",
            "english",
            "bilingual",
            "none"
          ]
        },
        "dialect_detected": {
          "type": [
            "string",
            "null"
          ]
        },
        "register": {
          "type": "string"
        },
        "tone": {
          "type": "string"
        },
        "notable_phrases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "call_to_action_present": {
          "type": "boolean"
        },
        "caption_text": {
          "type": [
            "string",
            "null"
          ],
          "description": "Full verbatim caption text as written on the post (Arabic, English, or both). Null if not yet extracted."
        },
        "caption_word_count": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Word count of caption_text. Null if caption_text is null."
        },
        "hashtag_count": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of hashtags in caption. Null if caption_text is null."
        },
        "has_emoji": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Whether the caption contains emoji. Null if caption_text is null."
        },
        "audio_strategy": {
          "type": [
            "object",
            "null"
          ],
          "description": "For video/reel content only. Null for image/carousel.",
          "additionalProperties": false,
          "properties": {
            "has_voiceover": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "voiceover_language": {
              "type": [
                "string",
                "null"
              ]
            },
            "music_type": {
              "type": [
                "string",
                "null"
              ],
              "description": "trending_sound / original_score / ambient / silence / sound_effects"
            },
            "has_subtitles": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        },
        "voiceover_text": {
          "type": [
            "string",
            "null"
          ],
          "description": "Whisper-transcribed spoken words"
        },
        "caption_sentiment": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "positive",
            "negative",
            "neutral",
            "question",
            null
          ],
          "description": "Lexicon-based sentiment of caption text"
        },
        "opener_formula": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "question",
            "command",
            "name_drop",
            "number",
            "emoji_open",
            "statement",
            null
          ],
          "description": "Opening pattern of caption: question/command/name_drop/number/emoji_open/statement"
        },
        "hook_type": {
          "type": [
            "string",
            "null"
          ],
          "description": "Caption opening hook pattern (GPT-4o-mini Phase 2 enrichment)",
          "enum": [
            "statement",
            "question",
            "command",
            "occasion_reference",
            "emoji_led",
            "arabic_idiom",
            "price_anchor",
            "none",
            null
          ]
        },
        "hook_text": {
          "type": [
            "string",
            "null"
          ],
          "description": "Verbatim opening words used as hook"
        },
        "cta_type": {
          "type": [
            "string",
            "null"
          ],
          "description": "Primary call-to-action type in caption",
          "enum": [
            "none",
            "order_now",
            "visit_store",
            "comment",
            "tag_someone",
            "follow",
            "contact",
            "pm_for_details",
            null
          ]
        },
        "arabic_technique": {
          "type": [
            "string",
            "null"
          ],
          "description": "Arabic language register/technique used in caption",
          "enum": [
            "colloquial_gulf",
            "colloquial_levantine",
            "bilingual_mix",
            "msa_formal",
            "english_only",
            "none",
            null
          ]
        },
        "emotion_words": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "description": "Key emotional or action words extracted from caption"
        },
        "has_saudi_dialect": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "local_idiom_flag": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "sarcasm_flag": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "compliance_check": {
      "type": "object",
      "required": [
        "hard_blocks_triggered",
        "soft_flags",
        "overall_compliance"
      ],
      "additionalProperties": false,
      "properties": {
        "hard_blocks_triggered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "forbidden_list_id",
              "entry_name",
              "severity",
              "evidence_description"
            ],
            "additionalProperties": false,
            "properties": {
              "forbidden_list_id": {
                "type": "string",
                "description": "ID from the forbidden list entry, e.g. '01KRKH1N2YF8H7F60EGJYQS3EW'"
              },
              "entry_name": {
                "type": "string",
                "description": "Name from the forbidden list, e.g. 'left_hand_serving'"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "severe",
                  "moderate",
                  "minor"
                ]
              },
              "evidence_description": {
                "type": "string",
                "minLength": 10,
                "description": "What was observed that triggered this block."
              }
            }
          }
        },
        "soft_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "flag_type",
              "description"
            ],
            "additionalProperties": false,
            "properties": {
              "flag_type": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "overall_compliance": {
          "type": "string",
          "enum": [
            "clean",
            "soft_flagged",
            "hard_blocked"
          ]
        }
      }
    },
    "cultural_notes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "regional_orientation_detected": {
          "type": [
            "string",
            "null"
          ]
        },
        "occasion_relevance": {
          "type": [
            "string",
            "null"
          ]
        },
        "hospitality_cues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "heritage_vs_modern": {
          "type": "string",
          "enum": [
            "heritage",
            "modern",
            "blended",
            "neutral"
          ]
        },
        "free_notes": {
          "type": "string"
        }
      }
    },
    "pattern_matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pattern_slug",
          "confidence"
        ],
        "additionalProperties": false,
        "properties": {
          "pattern_slug": {
            "type": "string",
            "description": "References a pattern in 11_who_to_learn_from/patterns/"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "strong",
              "moderate",
              "weak"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "quality_assessment": {
      "type": "object",
      "required": [
        "production_quality"
      ],
      "additionalProperties": false,
      "properties": {
        "production_quality": {
          "type": "string",
          "enum": [
            "professional",
            "semi_professional",
            "ugc",
            "low"
          ]
        },
        "brand_consistency_with_account": {
          "type": "string",
          "enum": [
            "strong",
            "moderate",
            "weak"
          ]
        },
        "engagement_potential": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "engagement_method": {
          "type": [
            "string",
            "null"
          ],
          "description": "How engagement_potential was determined (e.g. below_all_thresholds, rate_based, total_based)"
        }
      }
    },
    "provenance": {
      "$ref": "provenance_mixin_v1.schema.json"
    },
    "emotion_primary": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "joy",
        "trust",
        "anticipation",
        "pride",
        "appetite",
        "aspiration",
        "warmth",
        "urgency",
        "surprise",
        "neutral",
        "fear",
        "sadness",
        "anger",
        "disgust",
        null
      ]
    },
    "content_pillar": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "product",
        "lifestyle",
        "community",
        "educational",
        "entertainment",
        null
      ]
    },
    "content_pillar_confidence": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "high",
        "medium",
        "low",
        null
      ]
    },
    "data_quality_flag": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}